#!/usr/bin/env python3
"""Install Python packages with a security "cooldown" window.

Only releases that have been public for at least COOLDOWN_DAYS (default 14)
days are considered eligible for installation. This mitigates supply-chain
attacks where a freshly published -- and possibly compromised -- version of a
dependency would otherwise be pulled in the moment it appears on PyPI.

For every requested package the newest stable, non-yanked release whose files
were all uploaded at least COOLDOWN_DAYS ago is selected from the PyPI JSON
API, pinned to that exact version, and handed off to ``pip install``.

Usage:
    cooldown-pip [--days N] [--pip PIP_CMD] [-r requirements.txt] [pip-flags]
                 package [package ...]

Any unrecognised flags (e.g. ``--quiet``, ``--no-cache-dir``) are forwarded to
``pip install`` untouched.

NOTE: This file is intentionally duplicated into each Docker build context
(workbench, claude-codex, python, cvemaker) because every image is built with
its own context directory. The canonical copy lives in
``dockerfiles/workbench/scripts/cooldown-pip`` -- keep the copies in sync.
"""
import argparse
import json
import os
import re
import subprocess
import sys
import urllib.request
from datetime import datetime, timedelta, timezone

PYPI_URL = "https://pypi.org/pypi/{}/json"
# A "stable" release: digits and dots only (no a/b/rc/dev/post pre-releases).
STABLE_RE = re.compile(r"^[0-9]+(?:\.[0-9]+)*$")
# Strip extras / version specifiers to get the bare distribution name.
NAME_RE = re.compile(r"^([A-Za-z0-9._-]+)")


def log(msg):
    print(msg, file=sys.stderr, flush=True)


def fetch_metadata(name):
    url = PYPI_URL.format(name)
    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.load(resp)


def release_time(files):
    """Latest upload time among a release's (non-yanked) files, or None."""
    times = []
    for f in files:
        if f.get("yanked"):
            continue
        stamp = f.get("upload_time_iso_8601") or f.get("upload_time")
        if not stamp:
            continue
        stamp = stamp.replace("Z", "+00:00")
        try:
            dt = datetime.fromisoformat(stamp)
        except ValueError:
            continue
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        times.append(dt)
    return max(times) if times else None


def pick_version(name, cutoff):
    data = fetch_metadata(name)
    candidates = []
    for ver, files in data.get("releases", {}).items():
        if not STABLE_RE.match(ver):
            continue
        if not files:
            continue
        released = release_time(files)
        if released is None or released > cutoff:
            continue
        key = tuple(int(part) for part in ver.split("."))
        candidates.append((key, ver, released))
    if not candidates:
        raise SystemExit(
            "cooldown-pip: no stable release of '{}' is older than the "
            "cooldown cutoff ({})".format(name, cutoff.date())
        )
    candidates.sort()
    _, ver, released = candidates[-1]
    log("[cooldown-pip] {} -> {} (released {})".format(name, ver, released.date()))
    return ver


def bare_name(spec):
    m = NAME_RE.match(spec.strip())
    if not m:
        raise SystemExit("cooldown-pip: cannot parse package name from '{}'".format(spec))
    return m.group(1)


def read_requirements(path):
    names = []
    with open(path) as fh:
        for line in fh:
            line = line.split("#", 1)[0].strip()
            if not line or line.startswith("-"):
                continue
            names.append(line)
    return names


def main():
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument(
        "--days",
        type=int,
        default=int(os.environ.get("COOLDOWN_DAYS", "14")),
        help="minimum age in days a release must have (default: 14)",
    )
    parser.add_argument(
        "--pip",
        default=None,
        help="pip executable to use (default: this interpreter's '-m pip')",
    )
    parser.add_argument(
        "-r",
        "--requirement",
        action="append",
        default=[],
        help="requirements file(s); each listed package is cooldown-pinned",
    )
    parser.add_argument("packages", nargs="*", help="packages to install")
    args, pip_flags = parser.parse_known_args()

    specs = list(args.packages)
    for req in args.requirement:
        specs.extend(read_requirements(req))
    if not specs:
        raise SystemExit("cooldown-pip: no packages requested")

    cutoff = datetime.now(timezone.utc) - timedelta(days=args.days)
    log("[cooldown-pip] cutoff = {} (>= {} days old)".format(cutoff.date(), args.days))

    pins = []
    for spec in specs:
        name = bare_name(spec)
        version = pick_version(name, cutoff)
        pins.append("{}=={}".format(name, version))

    if args.pip:
        pip_cmd = args.pip.split()
    else:
        pip_cmd = [sys.executable, "-m", "pip"]
    cmd = pip_cmd + ["install"] + pip_flags + pins
    log("[cooldown-pip] running: {}".format(" ".join(cmd)))
    raise SystemExit(subprocess.call(cmd))


if __name__ == "__main__":
    main()
